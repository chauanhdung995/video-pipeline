{
  "name": "video-pipeline",
  "version": "1.0.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "catalog:studio": "node src/catalog-studio/server.js",
    "doctor": "node scripts/doctor.mjs",
    "hyperframes:doctor": "npx hyperframes doctor",
    "hyperframes:sync-blocks": "node scripts/sync_hyperframes_registry_blocks.mjs",
    "templates:scaffold": "node scripts/scaffold_template_catalog.mjs",
