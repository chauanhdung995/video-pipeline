  },
  "engines": {
    "node": ">=22 <26"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "express": "^4.19.2",
    "hyperframes": "^0.4.41",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2",
    "puppeteer": "^23.0.0",
    "ws": "^8.18.0"
  }
