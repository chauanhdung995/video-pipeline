  "updates": [
    {
      "time": "16:05",
      "text": "Một số tuyến chính đã hoạt động trở lại."
    },
    {
      "time": "16:20",
      "text": "Tuyến phụ vẫn được khuyến cáo hạn chế di chuyển."
    },
    {
      "time": "16:45",
      "text": "Cơ quan chức năng chuẩn bị phát thông báo tiếp theo."
    }
  ],
  "nextUpdate": "Cập nhật tiếp theo dự kiến 17:00",
  "background": {
    "type": "gradient",
    "colors": [
      "#05070d",
      "#101827",
      "#dc2626",
      "#22d3ee"
    ],
    "pattern": "clean breaking-news newsroom bands, low-contrast grid, red alert accents",
