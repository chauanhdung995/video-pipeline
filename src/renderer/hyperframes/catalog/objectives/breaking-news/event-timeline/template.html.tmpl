<section class="scene-template-event-timeline" data-template="event-timeline">
  <style>
    .scene-template-event-timeline,
    .scene-template-event-timeline * {
      box-sizing: border-box;
    }

    .scene-template-event-timeline {
      position: absolute;
      inset: 0;
      width: 1080px;
      height: 1920px;
      overflow: hidden;
      background: #05070d;
      color: #f8fafc;
      font-family: Inter, Arial, Helvetica, sans-serif;
      text-rendering: geometricPrecision;
      -webkit-font-smoothing: antialiased;
    }

    .scene-template-event-timeline .bg-gradient,
    .scene-template-event-timeline .bg-grid,
    .scene-template-event-timeline .bg-orb,
    .scene-template-event-timeline .bg-scan,
    .scene-template-event-timeline .bg-grain {
      position: absolute;
      inset: 0;
      pointer-events: none;
    }

    .scene-template-event-timeline .bg-gradient {
      background:
        radial-gradient(circle at 18% 12%, rgba(34, 211, 238, 0.24) 0, rgba(34, 211, 238, 0) 34%),
        radial-gradient(circle at 89% 18%, rgba(220, 38, 38, 0.40) 0, rgba(220, 38, 38, 0) 32%),
        radial-gradient(circle at 72% 82%, rgba(14, 165, 233, 0.18) 0, rgba(14, 165, 233, 0) 34%),
        linear-gradient(158deg, #05070d 0%, #0b1120 44%, #101827 66%, #111827 100%);
      animation: hfBgDrift 13s ease-in-out infinite alternate;
      transform: scale(1.08);
    }

    .scene-template-event-timeline .bg-grid {
      opacity: 0.22;
      background-image:
        linear-gradient(rgba(148, 163, 184, 0.13) 1px, transparent 1px),
        linear-gradient(90deg, rgba(148, 163, 184, 0.13) 1px, transparent 1px),
        linear-gradient(115deg, rgba(220, 38, 38, 0.16), rgba(34, 211, 238, 0.06) 42%, transparent 62%);
      background-size: 72px 72px, 72px 72px, 100% 100%;
      animation: hfGridSlide 18s linear infinite;
      mask-image: linear-gradient(to bottom, rgba(0,0,0,0.86), rgba(0,0,0,0.62) 62%, rgba(0,0,0,0.18));
    }

    .scene-template-event-timeline .bg-orb {
      inset: auto;
      width: 560px;
      height: 560px;
      right: -210px;
      top: 520px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(220, 38, 38, 0.22), rgba(220, 38, 38, 0.05) 46%, transparent 70%);
      filter: blur(4px);
      animation: hfOrbPulse 7s ease-in-out infinite;
    }

    .scene-template-event-timeline .bg-scan {
      background: linear-gradient(100deg, transparent 0%, transparent 41%, rgba(255,255,255,0.08) 49%, rgba(34,211,238,0.13) 50%, transparent 58%, transparent 100%);
      transform: translateX(-76%);
      animation: hfScan 6.5s ease-in-out infinite;
      mix-blend-mode: screen;
      opacity: 0.72;
    }

    .scene-template-event-timeline .bg-grain {
      opacity: 0.075;
      background-image:
        radial-gradient(circle at 20% 30%, rgba(255,255,255,0.55) 0 1px, transparent 1px),
        radial-gradient(circle at 70% 60%, rgba(255,255,255,0.38) 0 1px, transparent 1px);
      background-size: 17px 17px, 23px 23px;
      animation: hfGrain 1.3s steps(2) infinite;
    }

    .scene-template-event-timeline .frame-glow {
      position: absolute;
      inset: 54px;
      border: 1px solid rgba(148, 163, 184, 0.18);
      border-radius: 42px;
      box-shadow: inset 0 0 0 1px rgba(255,255,255,0.04), 0 0 72px rgba(220,38,38,0.10);
      pointer-events: none;
    }

    .scene-template-event-timeline .header {
      position: absolute;
      left: 126px;
      top: 104px;
      width: 840px;
      padding-bottom: 18px;
    }

    .scene-template-event-timeline .kicker-row {
      display: flex;
      align-items: center;
      gap: 16px;
      min-height: 52px;
    }

    .scene-template-event-timeline .live-dot {
      width: 16px;
      height: 16px;
      border-radius: 999px;
      background: #ef4444;
      box-shadow: 0 0 0 8px rgba(239,68,68,0.14), 0 0 28px rgba(239,68,68,0.80);
      animation: hfDotPulse 1.4s ease-in-out infinite;
      flex: 0 0 auto;
    }

    .scene-template-event-timeline .kicker {
      display: inline-flex;
      align-items: center;
      min-height: 44px;
      max-width: 680px;
      padding: 8px 18px 9px 18px;
      border: 1px solid rgba(248,250,252,0.18);
      border-radius: 999px;
      background: linear-gradient(90deg, rgba(220,38,38,0.72), rgba(127,29,29,0.38));
      color: #fff7ed;
      font-size: 25px;
      line-height: 1.32;
      font-weight: 850;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      white-space: normal;
      overflow-wrap: break-word;
      box-shadow: 0 18px 46px rgba(220,38,38,0.22);
    }

    .scene-template-event-timeline .title {
      margin-top: 22px;
      width: 820px;
      color: #ffffff;
      font-size: 78px;
      line-height: 1.18;
      font-weight: 920;
      letter-spacing: -0.055em;
      overflow-wrap: break-word;
      word-break: normal;
      padding-bottom: 12px;
      text-shadow: 0 16px 42px rgba(0,0,0,0.42);
    }

    .scene-template-event-timeline .title-accent {
      width: 206px;
      height: 8px;
      margin-top: 14px;
      border-radius: 999px;
      background: linear-gradient(90deg, #ef4444, #f97316 42%, #22d3ee);
      box-shadow: 0 0 26px rgba(239,68,68,0.48);
    }

    .scene-template-event-timeline .side-label {
      position: absolute;
      top: 118px;
      right: 74px;
      writing-mode: vertical-rl;
      text-orientation: mixed;
      color: rgba(226,232,240,0.42);
      font-size: 18px;
      line-height: 1.35;
      font-weight: 800;
      letter-spacing: 0.28em;
      text-transform: uppercase;
    }

    .scene-template-event-timeline .timeline-area {
      position: absolute;
      left: 94px;
      top: 448px;
      width: 910px;
      height: 930px;
    }

    .scene-template-event-timeline .rail {
      position: absolute;
      left: 154px;
      top: 18px;
      width: 5px;
      height: 852px;
      border-radius: 999px;
      background: linear-gradient(to bottom, rgba(34,211,238,0.28), rgba(239,68,68,0.92) 18%, rgba(248,250,252,0.45) 52%, rgba(34,211,238,0.82) 100%);
      box-shadow: 0 0 24px rgba(34,211,238,0.22), 0 0 34px rgba(239,68,68,0.17);
      overflow: hidden;
    }

    .scene-template-event-timeline .rail::after {
      content: '';
      position: absolute;
      left: 0;
      top: -160px;
      width: 100%;
      height: 160px;
      background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.95), transparent);
      animation: hfRailLight 3.4s ease-in-out infinite;
    }

    .scene-template-event-timeline .event-row {
      position: absolute;
      left: 0;
      width: 910px;
      height: 166px;
      opacity: 0;
      transform: translateY(22px);
      animation: hfCardIn 0.72s cubic-bezier(.2,.8,.2,1) forwards;
    }

    .scene-template-event-timeline .event-row.e1 { top: 0; animation-delay: 0.18s; }
    .scene-template-event-timeline .event-row.e2 { top: 178px; animation-delay: 0.34s; }
    .scene-template-event-timeline .event-row.e3 { top: 356px; animation-delay: 0.50s; }
    .scene-template-event-timeline .event-row.e4 { top: 534px; animation-delay: 0.66s; }
    .scene-template-event-timeline .event-row.e5 { top: 712px; animation-delay: 0.82s; }

    .scene-template-event-timeline .time-pill {
      position: absolute;
      left: 0;
      top: 34px;
      width: 130px;
      min-height: 58px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 8px 10px 9px 10px;
      border-radius: 18px;
      background: rgba(15,23,42,0.78);
      border: 1px solid rgba(226,232,240,0.18);
      box-shadow: 0 18px 42px rgba(0,0,0,0.35);
      color: #e0f2fe;
      font-size: 32px;
      line-height: 1.28;
      font-weight: 900;
      letter-spacing: -0.035em;
      overflow-wrap: break-word;
    }

    .scene-template-event-timeline .node {
      position: absolute;
      left: 133px;
      top: 42px;
      width: 48px;
      height: 48px;
      border-radius: 999px;
      background: #020617;
      border: 4px solid #f8fafc;
      box-shadow: 0 0 0 9px rgba(239,68,68,0.16), 0 0 30px rgba(34,211,238,0.30);
      z-index: 3;
    }

    .scene-template-event-timeline .node::after {
      content: '';
      position: absolute;
      inset: 10px;
      border-radius: 999px;
      background: linear-gradient(135deg, #ef4444, #22d3ee);
      animation: hfNodePulse 2.4s ease-in-out infinite;
    }

    .scene-template-event-timeline .event-card {
      position: absolute;
      left: 204px;
      top: 0;
      width: 690px;
      min-height: 158px;
      padding: 24px 28px 25px 30px;
      border-radius: 30px;
      background:
        linear-gradient(135deg, rgba(15,23,42,0.94), rgba(15,23,42,0.76)),
        linear-gradient(135deg, rgba(239,68,68,0.24), rgba(34,211,238,0.14));
      border: 1px solid rgba(226,232,240,0.16);
      box-shadow: 0 26px 58px rgba(0,0,0,0.42), inset 0 1px 0 rgba(255,255,255,0.06);
      overflow: visible;
    }

    .scene-template-event-timeline .event-card::before {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: inherit;
      background: linear-gradient(90deg, rgba(255,255,255,0.10), transparent 24%, transparent 74%, rgba(34,211,238,0.09));
      opacity: 0.66;
      pointer-events: none;
    }

    .scene-template-event-timeline .event-title {
      position: relative;
      color: #ffffff;
      font-size: 30px;
      line-height: 1.34;
      font-weight: 900;
      letter-spacing: -0.025em;
      overflow-wrap: break-word;
      word-break: normal;
      padding-bottom: 4px;
    }

    .scene-template-event-timeline .event-detail {
      position: relative;
      margin-top: 8px;
      color: rgba(226,232,240,0.88);
      font-size: 24px;
      line-height: 1.42;
      font-weight: 560;
      letter-spacing: -0.01em;
      overflow-wrap: break-word;
      word-break: normal;
    }

    .scene-template-event-timeline .footer-note {
      position: absolute;
      left: 172px;
      top: 1452px;
      width: 760px;
      min-height: 76px;
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 17px 22px 18px 22px;
      border-radius: 24px;
      background: rgba(2,6,23,0.58);
      border: 1px solid rgba(148,163,184,0.18);
      box-shadow: 0 20px 46px rgba(0,0,0,0.28);
      color: rgba(241,245,249,0.84);
      font-size: 24px;
      line-height: 1.38;
      font-weight: 650;
      overflow-wrap: break-word;
      word-break: normal;
    }

    .scene-template-event-timeline .footer-note::before {
      content: '';
      width: 14px;
      height: 14px;
      border-radius: 999px;
      background: #22d3ee;
      box-shadow: 0 0 18px rgba(34,211,238,0.62);
      flex: 0 0 auto;
    }

    .scene-template-event-timeline .bottom-band {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      height: 278px;
      background: linear-gradient(to bottom, transparent, rgba(2,6,23,0.88));
      pointer-events: none;
    }

    @keyframes hfBgDrift {
      0% { transform: scale(1.08) translate3d(-12px, -10px, 0); filter: saturate(1.02); }
      100% { transform: scale(1.12) translate3d(18px, 22px, 0); filter: saturate(1.18); }
    }

    @keyframes hfGridSlide {
      0% { background-position: 0 0, 0 0, 0 0; }
      100% { background-position: 72px 144px, 144px 72px, 0 0; }
    }

    @keyframes hfOrbPulse {
      0%, 100% { transform: translate3d(0, 0, 0) scale(0.96); opacity: 0.72; }
      50% { transform: translate3d(-34px, 28px, 0) scale(1.08); opacity: 0.92; }
    }

    @keyframes hfScan {
      0%, 24% { transform: translateX(-88%); opacity: 0; }
      42% { opacity: 0.70; }
      68%, 100% { transform: translateX(88%); opacity: 0; }
    }

    @keyframes hfGrain {
      0% { transform: translate(0,0); }
      50% { transform: translate(-8px,5px); }
      100% { transform: translate(4px,-6px); }
    }

    @keyframes hfDotPulse {
      0%, 100% { transform: scale(0.92); opacity: 0.78; }
      50% { transform: scale(1.16); opacity: 1; }
    }

    @keyframes hfRailLight {
      0% { transform: translateY(0); opacity: 0; }
      22% { opacity: 0.95; }
      100% { transform: translateY(1030px); opacity: 0; }
    }

    @keyframes hfCardIn {
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes hfNodePulse {
      0%, 100% { transform: scale(0.86); opacity: 0.84; }
      50% { transform: scale(1.08); opacity: 1; }
    }
  </style>

  <div class="bg-gradient"></div>
  <div class="bg-grid"></div>
  <div class="bg-orb"></div>
  <div class="bg-scan"></div>
  <div class="bg-grain"></div>
  <div class="frame-glow"></div>
  <div class="side-label">BREAKING UPDATE</div>

  <header class="header">
    <div class="kicker-row">
      <span class="live-dot"></span>
      <div class="kicker">{{templateData.kicker}}</div>
    </div>
    <div class="title">{{templateData.title}}</div>
    <div class="title-accent"></div>
  </header>

  <div class="timeline-area" aria-label="Event timeline">
    <div class="rail"></div>

    <article class="event-row e1">
      <div class="time-pill">{{templateData.events.0.time}}</div>
      <div class="node"></div>
      <div class="event-card">
        <div class="event-title">{{templateData.events.0.title}}</div>
        <div class="event-detail">{{templateData.events.0.detail}}</div>
      </div>
    </article>

    <article class="event-row e2">
      <div class="time-pill">{{templateData.events.1.time}}</div>
      <div class="node"></div>
      <div class="event-card">
        <div class="event-title">{{templateData.events.1.title}}</div>
        <div class="event-detail">{{templateData.events.1.detail}}</div>
      </div>
    </article>

    <article class="event-row e3">
      <div class="time-pill">{{templateData.events.2.time}}</div>
      <div class="node"></div>
      <div class="event-card">
        <div class="event-title">{{templateData.events.2.title}}</div>
        <div class="event-detail">{{templateData.events.2.detail}}</div>
      </div>
    </article>

    <article class="event-row e4">
      <div class="time-pill">{{templateData.events.3.time}}</div>
      <div class="node"></div>
      <div class="event-card">
        <div class="event-title">{{templateData.events.3.title}}</div>
        <div class="event-detail">{{templateData.events.3.detail}}</div>
      </div>
    </article>

    <article class="event-row e5">
      <div class="time-pill">{{templateData.events.4.time}}</div>
      <div class="node"></div>
      <div class="event-card">
        <div class="event-title">{{templateData.events.4.title}}</div>
        <div class="event-detail">{{templateData.events.4.detail}}</div>
      </div>
    </article>
  </div>

  <div class="footer-note">{{templateData.source}}</div>
  <div class="bottom-band"></div>
</section>