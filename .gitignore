# Dependencies
node_modules/

# Database (chứa API keys và dữ liệu nhạy cảm)
pipeline.db
pipeline.db-shm
pipeline.db-wal
*.db
*.db-shm
*.db-wal

# Sessions & output videos (dữ liệu tạm thời)
sessions/

# Uploads (file người dùng tải lên)
uploads/

# Cấu hình máy local (chứa đường dẫn tuyệt đối)
settings.json

# Media lớn (không phù hợp lưu trên git)
background-music/*
!background-music/.gitkeep
brand-specificities/*
!brand-specificities/.gitkeep

# Cache files
**/.media-cache.json
__pycache__/
*.py[cod]

# Generated voice sample cache
public/voice-samples/*
!public/voice-samples/.gitkeep

# Generated HyperFrames catalog previews
src/renderer/hyperframes/catalog/**/demo.mp4
src/renderer/hyperframes/catalog/**/_screenshots/
src/renderer/hyperframes/catalog/**/_prototypes/
src/renderer/hyperframes/catalog/**/work-*/

# Environment & secrets
.env
.env.*
!.env.example
*.key
*.pem

# macOS
.DS_Store
**/.DS_Store

# Claude Code internal
.sixth/

# Logs & temp
*.log
tmp/
temp/
